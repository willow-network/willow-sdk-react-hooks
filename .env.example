# React Hooks SDK Configuration
# ==============================
# Copy to .env for local development

# Willow node API endpoint
REACT_APP_WILLOW_API_URL=http://localhost:3031

# For Vite-based projects, use:
# VITE_WILLOW_API_URL=http://localhost:3031

# For Next.js projects, use:
# NEXT_PUBLIC_WILLOW_API_URL=http://localhost:3031
